generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
}

enum ProjectType {
  IMAGE
  VIDEO
  VOICE
  LOGO
  AVATAR
  THUMBNAIL
  AD
  SOCIAL
}

enum ProjectStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
}

enum AIModelProvider {
  OPENAI
  FLUX
  STABLE_DIFFUSION
  VEO
  RUNWAY
  KLING
  LUMA
  ELEVENLABS
}

enum ExportFormat {
  PNG
  JPG
  WEBP
  SVG
  GIF
  MP4
  MOV
  AVI
  WEBM
  PDF
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  avatar        String?
  plan          Plan     @default(FREE)
  credits       Int      @default(50)
  storageUsed   BigInt   @default(0)
  storageLimit  BigInt   @default(1073741824) // 1GB in bytes
  emailVerified Boolean  @default(false)
  twoFactorEnabled Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscription  Subscription?
  projects      Project[]
  generatedImages  GeneratedImage[]
  generatedVideos  GeneratedVideo[]
  voiceClones   VoiceClone[]
  apiKeys       ApiKey[]
  notifications Notification[]
  payments      Payment[]

  @@map("users")
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String             @unique
  plan              Plan               @default(FREE)
  status            SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime          @default(now())
  currentPeriodEnd  DateTime?
  credits           Int                @default(50)
  creditsUsed       Int                @default(0)
  stripeCustomerId  String?
  stripeSubscriptionId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Project {
  id        String      @id @default(cuid())
  userId    String
  name      String
  type      ProjectType
  status    ProjectStatus @default(DRAFT)
  thumbnail String?
  settings  Json?
  favorite  Boolean     @default(false)
  folder    String?
  tags      String[]
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectFiles    ProjectFile[]
  generatedImages GeneratedImage[]
  generatedVideos GeneratedVideo[]

  @@index([userId, type])
  @@index([userId, status])
  @@map("projects")
}

model ProjectFile {
  id        String   @id @default(cuid())
  projectId String
  name      String
  type      String
  url       String
  size      Int
  format    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_files")
}

model GeneratedImage {
  id         String   @id @default(cuid())
  userId     String
  projectId  String?
  prompt     String
  negativePrompt String?
  style      String?
  model      String?
  width      Int?
  height     Int?
  seed       Int?
  url        String
  settings   Json?
  createdAt  DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("generated_images")
}

model GeneratedVideo {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  prompt    String
  model     String?
  duration  Int?
  fps       Int?
  resolution String?
  url       String
  settings  Json?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("generated_videos")
}

model VoiceClone {
  id          String   @id @default(cuid())
  userId      String
  name        String
  voiceId     String
  samples     Int      @default(0)
  settings    Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("voice_clones")
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  name      String
  key       String   @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  type      String   @default("info")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  amount        Int
  currency      String   @default("usd")
  status        String
  stripePaymentId String?
  plan          Plan?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payments")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())

  @@map("admin_users")
}

model AIModel {
  id         String   @id @default(cuid())
  name       String
  provider   AIModelProvider
  type       String   // IMAGE, VIDEO, VOICE
  active     Boolean  @default(true)
  config     Json?
  costPerUse Int      @default(1)
  createdAt  DateTime @default(now())

  @@map("ai_models")
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json
  description String?

  @@map("system_configs")
}
